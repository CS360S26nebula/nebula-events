<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ============ SCROLLABLE CONTENT ============ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ======== HEADER ======== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textSize="28sp"
                        android:layout_marginTop="20sp"
                        android:layout_marginLeft="10sp"
                        android:textStyle="bold"
                        android:textColor="#111111" />

                    <TextView
                        android:id="@+id/greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome Back, Faculty"
                        android:textSize="14sp"
                        android:layout_marginLeft="10sp"

                        android:textColor="#888888"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/bellIcon"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/notifications"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- ======== STATUS CARDS GRID (Faculty: Approved, Rejected, Pending) ======== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp">

                <!-- Row 1: Approved + Rejected -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/approvedBox"
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:background="@drawable/badge_approved"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle"
                            android:tint="#111111" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Approved"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:layout_marginTop="3dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="10dp" android:layout_height="1dp" />

                    <LinearLayout
                        android:id="@+id/rejectedBox"
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:background="@drawable/badge_rejected"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_cancel"
                            android:tint="#111111" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rejected"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:layout_marginTop="3dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2: Pending (half-width, under Approved) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:id="@+id/pendingBox"
                        android:layout_width="0dp"
                        android:layout_height="76dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:background="@drawable/badge_pending"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_clock"
                            android:tint="#111111" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="#111111"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                android:layout_marginTop="3dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="10dp" android:layout_height="1dp" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                </LinearLayout>
            </LinearLayout>

            <!-- ======== AD-HOC REQUESTS SECTION ======== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="22dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ad-hoc Requests"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/viewAdHocBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="View"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#27374D"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <!-- ======== RECENT ACTIVITY ======== -->
            <TextView
                android:id="@+id/recentTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Activity"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginStart="20dp"
                android:layout_marginTop="22dp" />

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/search_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="12dp">

                <EditText
                    android:id="@+id/searchBox"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search"
                    android:background="@null"
                    android:textSize="14sp"
                    android:textColor="#111111"
                    android:textColorHint="#AAAAAA"
                    android:singleLine="true"
                    android:importantForAutofill="no" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="20dp"
                    android:background="#DDDDDD"
                    android:layout_marginEnd="10dp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_filter"
                    android:tint="#888888"
                    android:layout_marginEnd="12dp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    android:tint="#888888" />
            </LinearLayout>

            <!-- ======== GLASS RECENT ACTIVITY CARD ======== -->
            <LinearLayout
                android:id="@+id/recentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/glass_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pass ID:"
                            android:textColor="#666666"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID-12345678"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Approved"
                        android:textColor="@color/approved_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/badge_approved"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#C2C8D0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date &amp; Time"
                            android:textColor="#666666"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12th March 2026, 12:30pm"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#C2C8D0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guest Name"
                            android:textColor="#666666"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Moiz Imran"
                            android:textColor="#111111"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="View Details"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#DDE1E7"
                        app:strokeColor="#B2B8C2"
                        app:strokeWidth="1dp"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ======== BOTTOM NAVIGATION ======== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="31dp"
                android:layout_height="31dp"
                android:src="@drawable/home"
                android:tint="#27374D" />
            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="#27374D"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Download -->
        <LinearLayout
            android:id="@+id/navDownload"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/navDownloadIcon"
                android:layout_width="31dp"
                android:layout_height="31dp"
                android:src="@drawable/ic_download"
                android:tint="#111111" />

            <TextView
                android:id="@+id/navDownloadText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Download"
                android:textColor="#000000"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Submit Request (center, elevated) -->
        <LinearLayout
            android:id="@+id/navSubmitRequest"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2sp"
            android:layout_marginTop="-14dp"
            android:layout_weight="1"
            android:clickable="true"
            android:clipChildren="false"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_add_circle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Submit Request"
                android:textColor="#111111"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Passes -->
        <LinearLayout
            android:id="@+id/navPasses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/navPassesIcon"
                android:layout_width="31dp"
                android:layout_height="31dp"
                android:src="@drawable/file"
                android:layout_marginLeft="2sp"
                android:tint="#111111" />

            <TextView
                android:id="@+id/navPassesText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Passes"
                android:textColor="#000000"
                android:layout_marginLeft="2sp"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/navProfileIcon"
                android:layout_width="31dp"
                android:layout_height="31dp"
                android:src="@drawable/ic_profile"
                android:tint="#111111" />

            <TextView
                android:id="@+id/navProfileText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Profile"
                android:textColor="#111111"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/faculty_fragment_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="#F2F4F7"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
