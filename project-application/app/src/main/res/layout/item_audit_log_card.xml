<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/glass_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Row 1: Event ID + Type Badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_audit_event_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pass ID: P-0001"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Background and textColor set programmatically in AuditLogAdapter -->
        <TextView
            android:id="@+id/tv_audit_type_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Entry"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#E0E0E0" />

    <!-- Visitor name or emergency type -->
    <TextView
        android:id="@+id/tv_audit_visitor_or_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Visitor: Ali Raza"
        android:textColor="#222222"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <!-- Actor -->
    <TextView
        android:id="@+id/tv_audit_actor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Action By: Guard Usman (G-001)"
        android:textColor="#444444"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- Timestamp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_clock"
            android:contentDescription="Time"
            app:tint="#888888" />

        <TextView
            android:id="@+id/tv_audit_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="27 Apr 2026, 2:00 PM"
            android:textColor="#666666"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Detail — hidden when empty -->
    <TextView
        android:id="@+id/tv_audit_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Reason: Official meeting"
        android:textColor="#666666"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>