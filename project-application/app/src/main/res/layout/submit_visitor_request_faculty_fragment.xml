<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="54dp"
            android:paddingBottom="32dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Back"
                android:src="@drawable/keyboard_backspace" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-24dp"
                android:gravity="center"
                android:text="Submit Visitor Request"
                android:textColor="#27374D"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Visitor's Name"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_guest_name"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/person_dark"
                android:drawablePadding="8dp"
                android:hint="Enter full name"
                android:paddingHorizontal="10dp"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Visitor Type"
                android:textSize="13sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/person_dark" />

                <Spinner
                    android:id="@+id/sp_visitor_type"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/role_icon_anchor"
                    android:background="@android:color/transparent"
                    android:paddingStart="24dp"
                    android:spinnerMode="dropdown" />

                <View
                    android:id="@+id/role_icon_anchor"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_centerVertical="true" />

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/keyboard_arrow_down" />
            </RelativeLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Invitor's Name"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_invitor_name"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/person_dark"
                android:drawablePadding="8dp"
                android:hint="Enter full name"
                android:paddingHorizontal="10dp"
                android:textSize="11sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Visit Date"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_visit_date"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:clickable="true"
                android:drawableEnd="@drawable/date_range"
                android:drawablePadding="8dp"
                android:focusable="false"
                android:hint="MM/DD/YYYY"
                android:inputType="none"
                android:paddingHorizontal="10dp"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Visit Time"
                android:textSize="13sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="10dp">

                <Spinner
                    android:id="@+id/sp_visit_time"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:paddingStart="4dp"
                    android:spinnerMode="dropdown" />

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/keyboard_arrow_down" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="CNIC Number"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_cnic"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/identificationcard"
                android:drawablePadding="8dp"
                android:hint="Enter CNIC Number"
                android:paddingHorizontal="10dp"
                android:textSize="11sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Phone Number"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/phone_dark"
                android:drawablePadding="8dp"
                android:hint="Enter Phone Number"
                android:inputType="phone"
                android:paddingHorizontal="10dp"
                android:textSize="11sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Visit Reason"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_visit_reason"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:drawableStart="@drawable/person_dark"
                android:drawablePadding="8dp"
                android:hint="Enter reason"
                android:paddingHorizontal="10dp"
                android:textSize="11sp" />



            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit_request"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="28dp"
                android:text="Submit"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#27374D"
                app:cornerRadius="6dp" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>