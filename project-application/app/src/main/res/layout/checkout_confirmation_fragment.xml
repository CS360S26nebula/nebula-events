<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_overlay" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="15dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="6.5dp"
        app:cardElevation="12dp"
        app:strokeColor="#D9D9D9"
        app:strokeWidth="0.8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="26dp">

            <!-- Close X -->
            <ImageView
                android:id="@+id/btn_close_checkout_dialog"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/cross"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_checkout_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Confirm Check Out"
                android:textColor="#1E1E1E"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/btn_close_checkout_dialog"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_checkout_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Are you sure you want to log exit for:"
                android:textColor="#444444"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_checkout_title" />

            <!-- Shows visitor name dynamically -->
            <TextView
                android:id="@+id/tv_checkout_visitor_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#1E1E1E"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_checkout_message" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_checkout_visitor_name">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_checkout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="13dp"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:textColor="#1E1E1E"
                    app:backgroundTint="@color/btn_secondary"
                    app:cornerRadius="6.5dp"
                    app:strokeColor="#767676" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_confirm_checkout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Check Out"
                    android:textAllCaps="false"
                    android:textColor="#F5F5F5"
                    app:backgroundTint="@color/btn_primary"
                    app:cornerRadius="6.5dp"
                    app:strokeColor="#202F42" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>